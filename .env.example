# SuperPersonal Environment Variables
# Copy to .env and fill in your values.
# The client and server both read from this file.

# === Server (Google VM) ===
DJANGO_SECRET_KEY=change-me-to-a-random-64-char-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=34.182.12.121,localhost,127.0.0.1

# === Client (This PC) ===
# When using SSH tunnel, this stays localhost:8000
SUPERPERSONAL_SERVER_URL=http://localhost:8000/api/v1

# === SSH ===
SUPERPERSONAL_SSH_PROFILE=personal
SUPERPERSONAL_REMOTE_DIR=~/SuperPersonal
SUPERPERSONAL_LOCAL_PORT=8000
SUPERPERSONAL_REMOTE_PORT=8000
